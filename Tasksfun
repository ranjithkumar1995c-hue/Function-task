//Create a function to find LCM of two numbers.
	public static int LCM(int a,int b)
	{
		int x=a,y=b;
		while(y!=0) {
			int sum=y;
			y=x%y;
			x=sum;
		}
		return(a*b)/x;
		}
	public static void main(String[] args) {
